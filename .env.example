# Copy this file to .env and adjust the values for this machine.
# .env is gitignored — each machine (your Mac, the client's PC) keeps its own.

# Port the app listens on (serves both the API and the built frontend)
PORT=5050

# Where the SQLite database file lives on this machine.
# Leave commented to use ./payroll.db in the project folder.
# DB_PATH=./payroll.db

# Folder containing the legacy "PunchWay" Excel files (monthly paysheets +
# "blank pay sheet.xlsx"). Used for the employee roster import at startup
# and the one-time legacy data migration (npm run migrate-legacy).
# Defaults to ~/Desktop/PunchWay if not set.
PUNCHWAY_DATA_DIR=/absolute/path/to/PunchWay
